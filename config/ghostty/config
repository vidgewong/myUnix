# Font
font-family = mononoki Nerd Font
font-size = 18

# Cursor
cursor-style = block
cursor-style-blink = false
shell-integration-features = no-cursor

# Color scheme (Nord)
palette = 0=#3b4252
palette = 1=#bf616a
palette = 2=#a3be8c
palette = 3=#ebcb8b
palette = 4=#81a1c1
palette = 5=#b48ead
palette = 6=#88c0d0
